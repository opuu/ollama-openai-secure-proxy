{
    "name": "vps-llm",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "start": "bun run src/index.ts",
        "build": "bun build src/index.ts --outfile dist/server.js --target bun",
        "pm2:start": "pm2 start ecosystem.config.cjs --env production",
        "pm2:stop": "pm2 stop vps-llm",
        "pm2:restart": "pm2 restart vps-llm",
        "pm2:reload": "pm2 reload vps-llm",
        "pm2:logs": "pm2 logs vps-llm",
        "pm2:save": "pm2 save"
    },
    "devDependencies": {
        "@types/bun": "1.3.9",
        "@types/node": "^25.3.3"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.1",
        "elysia": "^1.4.26"
    }
}
