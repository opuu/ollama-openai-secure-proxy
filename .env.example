# ─── Required ────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys. Use `openssl rand -hex 32` to generate.
API_KEYS=your-secret-key-here,another-key-if-needed

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=3000

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Default model used when none is specified
DEFAULT_MODEL=qwen2.5:14b

# ─── CPU Throttling ───────────────────────────────────────────────────────────
# Threads per request. On an 8-core machine, 4 allows ~2 concurrent requests
# before CPU contention. Lower = more concurrent chats, slower individual responses.
# Recommended range for 8-core CPU: 3-6
NUM_THREADS=4

# Context window in tokens. Larger = more memory per loaded instance.
# 4096 is safe for 24 GB RAM with qwen2.5:14b (uses ~10 GB base).
NUM_CTX=4096

# ─── Model Aliases ────────────────────────────────────────────────────────────
# Override the default OpenAI→Ollama model mappings (comma-separated alias:target pairs)
# These let you point OpenAI SDK calls to your local models transparently.
# MODEL_ALIASES=gpt-4:qwen2.5:14b,gpt-3.5-turbo:qwen2.5:7b,gpt-3.5:qwen2.5:3b

# ─── Keep Alive ────────────────────────────────────────────────────────────────
# How long Ollama keeps a model in memory after the last request.
# -1 = forever, 0 = unload immediately, "30m" = 30 minutes
KEEP_ALIVE=-1

# ─── Warmup ───────────────────────────────────────────────────────────────────
# Comma-separated list of models to pre-load into Ollama memory on proxy startup.
# Eliminates the cold-start penalty on the first request to each model.
# IMPORTANT: Also set OLLAMA_MAX_LOADED_MODELS in the Ollama systemd service
# to match the number of models listed here (default Ollama limit is 1).
#
# To set it, run on the VPS:
#   sudo systemctl edit ollama
# Add:
#   [Service]
#   Environment="OLLAMA_MAX_LOADED_MODELS=6"
# Then: sudo systemctl restart ollama
WARMUP_MODELS=qwen2.5:1.5b-instruct,qwen2.5:3b,qwen2.5:7b,qwen2.5:14b,mistral:7b-instruct,phi3:mini

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your frontend domain in production, e.g.: https://myapp.com
CORS_ORIGIN=*

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_REQUESTS=true
